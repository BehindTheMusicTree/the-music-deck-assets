{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build and Run App",
			"type": "shell",
			"command": "PORT=3011 npm run dev",
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": [
				{
					"owner": "custom",
					"pattern": [{ "regexp": ".", "message": 1 }],
					"background": {
						"activeOnStart": true,
						"beginsPattern": "▲ Next\\.js|Compiling|starting",
						"endsPattern": "Ready in"
					}
				}
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}
