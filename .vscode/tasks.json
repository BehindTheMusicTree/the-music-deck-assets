{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Web: build then run dev (webpack)",
			"type": "shell",
			"command": "pnpm run build && pnpm run dev:webpack",
			"options": {
				"cwd": "${workspaceFolder}/apps/web",
				"env": { "PORT": "3011" }
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": [
				{
					"owner": "custom",
					"pattern": [{ "regexp": ".", "message": 1 }],
					"background": {
						"activeOnStart": true,
						"beginsPattern": "▲ Next\\.js|Compiling|starting",
						"endsPattern": "Ready in"
					}
				}
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}
