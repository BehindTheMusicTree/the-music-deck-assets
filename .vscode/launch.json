{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Launch app (dev)",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "dev:webpack"],
			"cwd": "${workspaceFolder}",
			"env": { "PORT": "3011" },
			"console": "integratedTerminal",
			"autoAttachChildProcesses": false
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Launch app (build and run)",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "launch"],
			"cwd": "${workspaceFolder}",
			"env": { "PORT": "3011" },
			"console": "integratedTerminal",
			"autoAttachChildProcesses": false
		},
		{
			"type": "chrome",
			"request": "launch",
			"name": "Open app in Chrome",
			"preLaunchTask": "Build then Run Dev App",
			"url": "http://localhost:3011",
			"webRoot": "${workspaceFolder}"
		}
	]
}
