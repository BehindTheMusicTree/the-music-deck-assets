generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CardRarity {
  LEGENDARY
  CLASSIC
  BANGER
  NICHE
}

enum CardKind {
  SONG
  TRANSITION
}

enum Intensity {
  POP
  SOFT
  EXPERIMENTAL
  HARDCORE
}

/** Registry of all valid two-character TYPE segments.
 *  Both Genre.code and Territory.code FK here, so a code can never be
 *  used by two rows in the same table (unique FKs) — cross-table exclusivity
 *  is validated at seed time. */
model TypeCode {
  code String @id @db.VarChar(2)

  genre     Genre?
  territory Territory?
}

/** One row per territory (sovereign state or significant sub-national region).
 *  Seeded from TERRITORY_PRINTED_TYPE_CODE in cards-domain — do not edit manually. */
model Territory {
  id       Int      @id @default(autoincrement())
  /** FK into TypeCode — guarantees the code is registered and unique across the registry. */
  code     String   @unique @db.VarChar(2)
  typeCode TypeCode @relation(fields: [code], references: [code])
  name     String   @unique

  genres     Genre[]
  songCards  SongCard[]
}

model Genre {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  displayLabel String?

  // Hierarchy: null for root genres and country subgenres; points to parent root Genre for genre-linked subgenres
  parentId Int?
  parent   Genre?  @relation("SubgenreParent", fields: [parentId], references: [id])
  children Genre[] @relation("SubgenreParent")

  // Blend: second parent (e.g. Jungle = Electronic + Reggae/Dub)
  parentBId     Int?
  parentB       Genre?  @relation("BlendParentB", fields: [parentBId], references: [id])
  blendChildren Genre[] @relation("BlendParentB")

  intensity     Intensity
  colorOverride String?

  // Transition/influence hint for GenreSubgenre
  influenceId        Int?
  influenceRef       Genre?  @relation("SubgenreInfluence", fields: [influenceId], references: [id])
  influenced         Genre[] @relation("SubgenreInfluence")
  influenceIntensity Intensity?

  // Root genres only
  wheelOrder Int?

  /** TYPE segment (two chars) — set on root genres, null on subgenres.
   *  References TypeCode to enforce global uniqueness across genres and territories. */
  code     String?   @unique @db.VarChar(2)
  typeCode TypeCode? @relation(fields: [code], references: [code])

  /** Country-linked subgenres only — points to the territory that anchors this style. */
  parentTerritoryId Int?
  parentTerritory   Territory? @relation(fields: [parentTerritoryId], references: [id])

  theme Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  songs           SongCard[]
  transitionCards TransitionCard[]
}

model Card {
  id                 Int      @id
  rowKey             String   @unique
  kind               CardKind
  title              String
  artworkKey         String?
  artworkContentType String?
  artworkBytes       Int?
  artworkChecksum    String?
  artworkOffsetY     Int?
  artworkOverBorder  Boolean  @default(false)
  artworkCreatedAt   DateTime?
  artworkPrompt      String?  @db.Text
  /** Immutable player-facing catalogue id after first print lock (e.g. RK-S1-023, FR-S1-005). */
  printedSetId       String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  songCard       SongCard?
  transitionCard TransitionCard?
}

model SongCard {
  id            Int      @id
  card          Card     @relation(fields: [id], references: [id], onDelete: Cascade)
  /// When set, must be non-empty after trim (DB check). Omit or null when unknown.
  artist        String?
  year          String?
  genreId       Int?
  genreRef      Genre?     @relation(fields: [genreId], references: [id])
  territoryId   Int?
  territory     Territory? @relation(fields: [territoryId], references: [id])
  ability       String
  abilityDesc   String
  pop           Int
  rarity        CardRarity
  catalogNumber Int?
  wikipediaUrl  String?
  spotifyUrl    String?
  appleMusicUrl String?
  youtubeUrl    String?
  bandcampUrl   String?
  soundcloudUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  songsOut SongSongTransition[] @relation("from")
  songsIn  SongSongTransition[] @relation("to")
}

model WishlistSong {
  id            Int      @id
  rowKey        String   @unique
  title         String
  /// When set, must be non-empty after trim (DB check). Omit or null when unknown.
  artist        String?
  year          String?
  genre         String?
  country       String?
  ability       String?
  abilityDesc   String?
  pop           Int?
  rarity        CardRarity?
  artworkPrompt String?  @db.Text
  wikipediaUrl  String?
  spotifyUrl    String?
  appleMusicUrl String?
  youtubeUrl    String?
  bandcampUrl   String?
  soundcloudUrl String?
  comment       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TransitionCard {
  id        Int      @id
  card      Card     @relation(fields: [id], references: [id], onDelete: Cascade)
  genre     String?
  genreId   Int?
  genreRef  Genre?   @relation(fields: [genreId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SongSongTransition {
  fromId Int
  toId   Int

  from SongCard @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  to   SongCard @relation("to", fields: [toId], references: [id], onDelete: Cascade)

  @@id([fromId, toId])
  @@index([toId])
}

model BattleAudio {
  id          Int       @id @default(autoincrement())
  /// Slug identifying the combination, e.g. "genre-rock--intensity-experimental", "country-france"
  token       String
  version     Int       @default(1)
  audioKey    String
  contentType String    @default("audio/mpeg")
  bytes       Int
  checksum    String
  durationSec Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([token, version])
}
