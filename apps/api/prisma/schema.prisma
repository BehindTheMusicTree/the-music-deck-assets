// Prisma schema for the Music Deck admin API.
// Run `pnpm --filter api prisma migrate dev` after edits.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CardStatus {
  Shipped
  Wishlist
  Planned
}

enum CardRarity {
  Legendary
  Classic
  Banger
  Niche
}

enum Intensity {
  pop
  soft
  experimental
  hardcore
}

model Genre {
  id   Int    @id @default(autoincrement())
  name String @unique

  // Hierarchy: null for AppGenre; points to parent AppGenre row for subgenres
  parentId  Int?
  parent    Genre?  @relation("SubgenreParent", fields: [parentId], references: [id])
  children  Genre[] @relation("SubgenreParent")

  // Blend: second parent (e.g. Jungle = Electronic + Reggae/Dub @ t=0.42)
  parentBId     Int?
  parentB       Genre?  @relation("BlendParentB", fields: [parentBId], references: [id])
  blendChildren Genre[] @relation("BlendParentB")
  blendFactor   Float?

  intensity     Intensity
  colorOverride String?

  // Transition/influence hint for GenreSubgenre
  influenceId        Int?
  influenceRef       Genre?  @relation("SubgenreInfluence", fields: [influenceId], references: [id])
  influenced         Genre[] @relation("SubgenreInfluence")
  influenceIntensity Intensity?

  // AppGenre only
  displayLabel String?
  wheelOrder   Int?
  isCountry    Boolean  @default(false)

  theme Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  songCards SongCard[]
}

model Card {
  id          Int        @id
  rowKey      String     @unique
  status      CardStatus
  title       String
  pop         Int
  rarity      CardRarity
  ability     String
  abilityDesc String

  // Artwork bytes live in the S3-compatible bucket; DB only stores the object key + metadata.
  artworkKey         String?
  artworkContentType String?
  artworkBytes       Int?
  artworkChecksum    String?
  artworkOffsetY     Int?
  artworkOverBorder  Boolean   @default(false)
  artworkCreatedAt   DateTime?
  artworkPrompt      String?   @db.Text

  wikipediaUrl   String?
  spotifyUrl     String?
  appleMusicUrl  String?
  youtubeUrl     String?
  bandcampUrl    String?
  soundcloudUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  songCard SongCard?
}

model SongCard {
  id      Int  @id
  card    Card @relation(fields: [id], references: [id], onDelete: Cascade)

  artist        String?
  year          String
  genre         String
  genreId       Int?
  genreRef      Genre?  @relation(fields: [genreId], references: [id])
  country       String?
  catalogNumber Int?

  tracksOut SongCardTrackTransition[] @relation("from")
  tracksIn  SongCardTrackTransition[] @relation("to")
}

model SongCardTrackTransition {
  fromId Int
  toId   Int

  from SongCard @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  to   SongCard @relation("to", fields: [toId], references: [id], onDelete: Cascade)

  @@id([fromId, toId])
  @@index([toId])
}
