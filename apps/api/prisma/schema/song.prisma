model SongCard {
  id            Int      @id
  card          Card     @relation(fields: [id], references: [id], onDelete: Cascade)
  /// When set, must be non-empty after trim (DB check).
  artist        String?
  year          String?
  genreId       Int?
  genreRef      Genre?   @relation(fields: [genreId], references: [id])
  country       String?
  ability       String
  abilityDesc   String
  pop           Int
  rarity        CardRarity
  catalogNumber Int?
  wikipediaUrl  String?
  spotifyUrl    String?
  appleMusicUrl String?
  youtubeUrl    String?
  bandcampUrl   String?
  soundcloudUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  songsOut SongSongTransition[] @relation("from")
  songsIn  SongSongTransition[] @relation("to")
}

