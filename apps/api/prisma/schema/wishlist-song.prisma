model WishlistSong {
  id            Int         @id
  rowKey        String      @unique
  title         String
  /// When set, must be non-empty after trim (DB check). Omit or null when unknown.
  artist        String?
  year          String?
  genre         String?
  country       String?
  ability       String?
  abilityDesc   String?
  pop           Int?
  rarity        CardRarity?
  artworkPrompt String?     @db.Text
  wikipediaUrl  String?
  spotifyUrl    String?
  appleMusicUrl String?
  youtubeUrl    String?
  bandcampUrl   String?
  soundcloudUrl String?
  comment       String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

