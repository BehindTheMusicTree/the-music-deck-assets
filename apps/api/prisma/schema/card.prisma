// Kept in sync with root `schema.prisma` (generator entry point). Prisma loads `prisma/schema.prisma` only.

model Card {
  id                 Int       @id
  rowKey             String    @unique
  kind               CardKind
  title              String
  artworkKey         String?
  artworkContentType String?
  artworkBytes       Int?
  artworkChecksum    String?
  artworkOffsetY     Int?
  artworkOverBorder  Boolean   @default(false)
  artworkCreatedAt   DateTime?
  artworkPrompt      String?   @db.Text
  printedSetId       String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  songCard       SongCard?
  transitionCard TransitionCard?
}
