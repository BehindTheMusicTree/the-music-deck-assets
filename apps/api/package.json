{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --config jest.config.cjs",
    "prisma:generate": "set -a && . ./.env && set +a && prisma generate",
    "prisma:migrate:dev": "set -a && . ./.env && set +a && prisma migrate dev",
    "prisma:migrate:deploy": "set -a && . ./.env && set +a && prisma migrate deploy",
    "prisma:migrate:reset": "set -a && . ./.env && set +a && prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "set -a && . ./.env && set +a && prisma migrate reset --force && pnpm db:seed && pnpm artworks:migrate",
    "artworks:migrate": "tsx scripts/migrate-artworks.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.2",
    "@prisma/client": "^6.18.0",
    "@repo/cards-domain": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "multer": "^2.1.1",
    "prisma": "^6.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
